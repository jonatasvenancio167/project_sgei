<div id="<%= id %>" 
     class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6 hidden opacity-0 transition-all duration-300 ease-in-out"
     data-controller="modal"
     data-modal-target="container"
     role="dialog" 
     aria-modal="true">
  
  <!-- Backdrop -->
  <div class="fixed inset-0 bg-background/80 backdrop-blur-sm transition-opacity" 
       data-action="click->modal#close"></div>

  <!-- Modal Content -->
  <div class="relative w-full overflow-hidden rounded-2xl border border-border/60 bg-card p-0 shadow-2xl transition-all sm:my-8 <%= modal_classes %>"
       style="box-shadow: var(--shadow-soft)">
    
    <div class="flex flex-col max-h-[90vh]">
      <!-- Header -->
      <div class="px-6 py-5 border-b border-border/40">
        <div class="flex items-start justify-between">
          <div>
            <% if header %>
              <%= header %>
            <% else %>
              <h3 class="font-serif text-2xl leading-none tracking-tight"><%= title %></h3>
              <% if description %>
                <p class="mt-1.5 text-sm text-muted-foreground"><%= description %></p>
              <% end %>
            <% end %>
          </div>
          <button type="button" 
                  class="rounded-lg p-1 text-muted-foreground hover:bg-secondary hover:text-foreground transition-colors"
                  data-action="click->modal#close">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-x size-4"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
            <span class="sr-only">Fechar</span>
          </button>
        </div>
      </div>

      <!-- Body -->
      <div class="px-6 py-6 overflow-y-auto flex-1">
        <%= body || content %>
      </div>

      <!-- Footer -->
      <% if footer %>
        <div class="px-6 py-4 border-t border-border/40 bg-secondary/10 flex flex-col-reverse sm:flex-row sm:justify-end sm:gap-3">
          <%= footer %>
        </div>
      <% end %>
    </div>
  </div>
</div>
