<%= render(Sidebar::ProviderComponent.new) do %>
  <%= render(Sidebar::SidebarComponent.new(variant: :sidebar)) do %>
    <%= render(Sidebar::HeaderComponent.new) do %>
      <%= link_to root_path, class: "flex items-center gap-3 px-2 py-4 no-underline" do %>
        <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-primary text-primary-foreground shadow-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-church size-6"><path d="M10 20v-5h4v5"/><path d="M7 20h10a2 2 0 0 0 2-2V8l-7-5-7 5v10a2 2 0 0 0 2 2Z"/><path d="M12 7v4"/><path d="M10 9h4"/></svg>
        </div>
        <span class="text-2xl font-serif text-sidebar-foreground">Ekklesia</span>
      <% end %>
    <% end %>

    <%= render(Sidebar::ContentComponent.new) do %>
      <%= render(Sidebar::GroupComponent.new) do %>
        <%= render(Sidebar::MenuComponent.new) do %>
          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new(is_active: current_page?(root_path), href: root_path)) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-layout-grid size-4"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
              <span>Visão geral</span>
            <% end %>
          <% end %>

          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new(is_active: controller_name == 'calendario', href: calendario_path)) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-days size-4"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
              <span>Calendário</span>
            <% end %>
          <% end %>

          <%# Repeat for other items with proper path helpers if available %>
          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new(is_active: controller_name == 'events', href: painel_eventos_path)) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar size-4"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              <span>Eventos</span>
            <% end %>
          <% end %>

          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new(is_active: controller_name == 'departaments', href: departaments_path)) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users size-4"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span>Departamentos</span>
            <% end %>
          <% end %>

          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new(is_active: request.path == painel_membros_path, href: painel_membros_path)) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-user size-4"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Membros</span>
            <% end %>
          <% end %>

          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new(is_active: controller_name == 'forms', href: forms_path)) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clipboard-list size-4"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
              <span>Formulários</span>
            <% end %>
          <% end %>
        <% end %>
      <% end %>

      <div class="mt-auto">
        <%= render(Sidebar::MenuComponent.new) do %>
          <%= render(Sidebar::MenuItemComponent.new) do %>
            <%= render(Sidebar::MenuButtonComponent.new) do %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-settings size-4"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
              <span>Configurações</span>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <%= render(Sidebar::FooterComponent.new) do %>
      <div class="mt-4 rounded-xl border border-border/60 bg-card p-3 text-xs">
        <p class="font-medium"><%= current_user&.name || current_user&.email || "Usuário" %></p>
        <p class="text-muted-foreground">
          <%= current_user&.role&.capitalize %>
          <% if current_user&.respond_to?(:department) && current_user.department.present? %>
            <%= " · #{current_user.department}" %>
          <% end %>
        </p>
        <%= button_to destroy_user_session_path, method: :delete, class: "mt-2 inline-flex items-center gap-1 text-muted-foreground hover:text-foreground transition-colors bg-transparent border-0 p-0 cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-log-out size-3"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <span class="text-[10px]">Sair</span>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render(Sidebar::InsetComponent.new) do %>
    <header class="flex h-16 shrink-0 items-center gap-2 border-b px-4">
      <%= render(Sidebar::TriggerComponent.new) %>
      <div class="h-4 w-[1px] bg-border"></div>
      <div class="text-sm font-medium"><%= content_for(:title) || "Visão geral" %></div>
    </header>
    
    <div class="flex-1 overflow-auto">
      <%= yield %>
    </div>
  <% end %>
<% end %>
