<div class="mt-8 overflow-hidden rounded-2xl border border-border/60 bg-card" style="box-shadow: var(--shadow-soft)">
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead class="bg-secondary/50 text-left text-xs uppercase tracking-wide text-muted-foreground">
        <tr>
          <th class="px-5 py-4 font-semibold text-center w-32">Quando</th>
          <th class="px-5 py-4 font-semibold text-left">Evento</th>
          <th class="px-5 py-4 font-semibold text-left">Local</th>
          <th class="px-5 py-4 font-semibold text-center w-40">Departamento</th>
          <th class="px-5 py-4 font-semibold text-center w-32">Visibilidade</th>
          <th class="px-5 py-4 font-semibold text-center w-24">Inscritos</th>
        </tr>
      </thead>
      <tbody id="events_table_body">
        <% if decorator.events.empty? %>
          <tr>
            <td colSpan="6" class="px-5 py-12 text-center text-muted-foreground">
              <div class="flex flex-col items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-days h-10 w-10 opacity-20"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
                <p class="text-base font-medium">Nenhum evento encontrado</p>
                <p class="text-sm">Tente ajustar seus filtros para encontrar o que procura.</p>
                <% if decorator.has_active_filters? %>
                  <%= link_to "Limpar filtros", painel_eventos_path, class: "mt-2 inline-flex items-center justify-center rounded-md border border-input bg-background px-4 py-2 text-sm font-medium transition-colors hover:bg-accent focus:outline-none" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% else %>
          <% decorator.decorated_events.each do |event| %>
            <%= render partial: "events/event_row", locals: { event: event } %>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
  
  <% if @pagy.pages > 1 %>
    <div class="flex items-center justify-between border-t border-border/60 bg-secondary/20 px-6 py-4">
      <div class="text-xs text-muted-foreground">
        Exibindo <span class="font-medium text-foreground"><%= @pagy.from %></span> a <span class="font-medium text-foreground"><%= @pagy.to %></span> de <span class="font-medium text-foreground"><%= @pagy.count %></span> eventos
      </div>
      <div class="pagy-nav">
        <%== pagy_nav(@pagy) %>
      </div>


    </div>
  <% end %>
</div>

