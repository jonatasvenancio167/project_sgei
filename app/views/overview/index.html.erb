<div class="mx-auto max-w-6xl p-8 lg:p-12">
  <header class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-sm text-muted-foreground">Bem-vindo de volta</p>
      <h1 class="mt-1 font-serif text-4xl">Visão geral da agenda</h1>
      <% if @user && !@user.admin? %>
        <p class="mt-1 text-sm text-muted-foreground"><%= @user.role_label %> · <%= @user.primary_department_name %></p>
      <% end %>
    </div>
    <p class="text-sm text-muted-foreground">Hoje · <%= I18n.l(Date.today, format: :long) %></p>
  </header>

  <section class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <% @stats.each do |s| %>
      <div class="rounded-2xl border border-border/60 bg-card p-5" style="box-shadow: var(--shadow-soft)">
        <div class="flex items-center justify-between">
          <p class="text-sm text-muted-foreground"><%= s[:label] %></p>
          <div class="text-primary">
            <% if s[:icon] == "calendar-days" %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar-days size-4"><path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/></svg>
            <% elsif s[:icon] == "clipboard-list" %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-clipboard-list size-4"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
            <% elsif s[:icon] == "users" %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-users size-4"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <% elsif s[:icon] == "trending-up" %>
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-trending-up size-4"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
            <% end %>
          </div>
        </div>
        <p class="mt-3 font-serif text-4xl"><%= s[:value] %></p>
        <p class="mt-1 text-xs text-muted-foreground"><%= s[:hint] %></p>
      </div>
    <% end %>
  </section>

  <section class="mt-10 grid gap-6 lg:grid-cols-3">
    <div class="rounded-2xl border border-border/60 bg-card p-6 lg:col-span-2" style="box-shadow: var(--shadow-soft)">
      <div class="flex items-center justify-between">
        <h2 class="font-serif text-2xl">Próximos eventos</h2>
        <span class="text-xs text-muted-foreground">Próximos 7 dias</span>
      </div>
      <ul class="mt-5 space-y-3">
        <% if @upcoming_events.empty? %>
          <li class="text-sm text-muted-foreground">Nenhum evento para o seu perfil nos próximos dias.</li>
        <% end %>
        <% @upcoming_events.each do |e| %>
          <li class="flex items-center gap-3 rounded-xl border border-border/60 bg-background/40 p-3">
            <span class="h-12 w-1.5 rounded-full <%= e.departament&.name == 'Louvor & Adoração' ? 'bg-primary' : 'bg-chart-3' %>"></span>
            <div class="flex-1">
              <p class="text-sm font-medium"><%= e.title %></p>
              <p class="text-xs text-muted-foreground"><%= I18n.l(e.start_date, format: :short) %> · <%= e.location %></p>
            </div>
            <span class="rounded-full bg-secondary px-3 py-1 text-xs text-secondary-foreground"><%= e.departament&.name || "Geral" %></span>
          </li>
        <% end %>
      </ul>
    </div>

    <div class="rounded-2xl border border-border/60 bg-card p-6" style="box-shadow: var(--shadow-soft)">
      <h2 class="font-serif text-2xl">Inscrições</h2>
      <ul class="mt-5 space-y-3">
        <% if @active_forms.empty? %>
          <li class="text-sm text-muted-foreground">Nenhuma inscrição aberta.</li>
        <% end %>
        <% @active_forms.each do |f| %>
          <li class="rounded-xl border border-border/60 p-3">
            <div class="flex items-center justify-between">
              <p class="text-sm font-medium"><%= f.title %></p>
              <span class="rounded-full px-2.5 py-0.5 text-[10px] bg-primary/15 text-primary">Aberto</span>
            </div>
            <p class="mt-1 text-xs text-muted-foreground">Inscrição para <%= f.event.title %></p>
          </li>
        <% end %>
      </ul>
    </div>
  </section>
</div>