<div class="min-h-screen grid place-items-center bg-background px-4">
  <div class="w-full max-w-sm">
    <a href="/" class="mb-8 flex items-center justify-center gap-2">
      <span class="grid h-10 w-10 place-items-center rounded-xl bg-primary text-primary-foreground shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-church">
          <path d="m18 7 4 2v11a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9l4-2" />
          <path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4" />
          <path d="M18 5v17" />
          <path d="M6 5v17" />
          <circle cx="12" cy="9" r="2" />
          <path d="M12 2v5" />
          <path d="M10 4h4" />
        </svg>
      </span>
      <span class="font-serif text-2xl text-foreground">Ekklesia</span>
    </a>

    <div class="rounded-2xl border border-border/60 bg-card p-6 shadow-sm">
      <h1 class="font-serif text-3xl text-foreground">Entrar</h1>
      <p class="mt-1 text-sm text-muted-foreground">
        Acesse o painel da secretaria.
      </p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
        <div class="space-y-2">
          <%= f.label :email, "Usuário", class: "text-sm font-medium leading-none text-foreground" %>
          <%= f.email_field :email, 
                autofocus: true, 
                autocomplete: "username", 
                placeholder: "teste",
                required: true,
                class: "flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50" %>
        </div>

        <div class="space-y-2">
          <%= f.label :password, "Senha", class: "text-sm font-medium leading-none text-foreground" %>
          <%= f.password_field :password, 
                autocomplete: "current-password", 
                placeholder: "teste",
                required: true,
                class: "flex h-10 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm shadow-sm transition-colors file:border-0 file:bg-transparent file:text-sm file:font-medium placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:cursor-not-allowed disabled:opacity-50" %>
        </div>

        <% if alert %>
          <p class="text-sm text-destructive"><%= alert %></p>
        <% end %>

        <%= f.submit "Entrar", class: "inline-flex h-10 w-full items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 cursor-pointer" %>
      <% end %>

      <p class="mt-6 text-center text-sm text-muted-foreground">
        Não tem conta? 
        <%= link_to "Criar conta", new_registration_path(resource_name), class: "font-medium text-foreground hover:underline" %>
      </p>

      <div class="mt-3 space-y-1 text-center text-xs text-muted-foreground">
        <p>Contas demo:</p>
        <p><span class="font-mono">teste/teste</span> · Secretaria</p>
        <p><span class="font-mono">lider/lider</span> · Líder de Louvor</p>
        <p><span class="font-mono">membro/membro</span> · Membro de Jovens</p>
      </div>
    </div>
  </div>
</div>
